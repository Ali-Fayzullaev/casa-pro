generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  password            String
  role                UserRole
  firstName           String              @map("first_name")
  lastName            String              @map("last_name")
  phone               String?
  city                String? // New: broker city
  balance             Decimal             @default(0) @db.Decimal(15, 2) // New: current balance
  casaFee             Decimal             @default(0) @map("casa_fee") @db.Decimal(15, 2) // New: total Casa fees
  certificationStatus CertificationStatus @default(IN_PROGRESS) @map("certification_status") // New
  curatorId           String?             @map("curator_id") // New: assigned curator
  curatorName         String?             @map("curator_name") // Curator display name
  curatorPhone        String?             @map("curator_phone") // Curator phone
  curatorEmail        String?             @map("curator_email") // Curator email  
  curatorWhatsApp     String?             @map("curator_whatsapp") // Curator WhatsApp
  isActive            Boolean             @default(true) @map("is_active")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  // Relations
  bookings       Booking[]
  clients        Client[]
  projects       Project[]        @relation("DeveloperProjects")
  courseProgress CourseProgress[]
  notifications  Notification[]
  tasks          Task[]
  deals          Deal[]
  properties     Property[]       @relation("BrokerProperties")
  curator        User?            @relation("CuratorBrokers", fields: [curatorId], references: [id])
  brokers        User[]           @relation("CuratorBrokers")
  payments       Payment[]
  forms          LeadForm[]       @relation("FormBrokers")

  @@map("users")
}

model Client {
  id             String       @id @default(cuid())
  iin            String       @unique
  firstName      String       @map("first_name")
  lastName       String       @map("last_name")
  middleName     String?      @map("middle_name") @db.VarChar
  phone          String
  email          String?
  city           String?      // город клиента
  clientType     ClientType   @default(BUYER) @map("client_type") // New: BUYER/SELLER
  budget         Decimal?     @db.Decimal(15, 2) // New: client budget
  status         ClientStatus @default(NEW)
  monthlyIncome  Decimal?     @map("monthly_income") @db.Decimal(15, 2)
  initialPayment Decimal?     @map("initial_payment") @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  brokerId       String       @map("broker_id")

  // Relations
  bookings             Booking[]
  documents            ClientDocument[]
  broker               User                  @relation(fields: [brokerId], references: [id])
  mortgageCalculations MortgageCalculation[]
  sellingProperties    Property[]            @relation("SellerProperties")
  boughtProperties     Property[]            @relation("BuyerProperties")
  deals                Deal[]

  @@index([brokerId])
  @@index([status])
  @@index([clientType])
  @@map("clients")
}

model Project {
  id               String         @id @default(cuid())
  name             String
  description      String?
  city             String
  district         String? // New: район
  address          String
  lat              Float?  // Широта для карты
  lng              Float?  // Долгота для карты
  class            String? // эконом, комфорт, бизнес
  buildingStatus   BuildingStatus @default(UNDER_CONSTRUCTION) @map("building_status") // New
  deliveryDate     DateTime?      @map("delivery_date")
  developerName    String?        @map("developer_name") // New: застройщик
  developerPhone   String?        @map("developer_phone") // New
  crmUrl           String?        @map("crm_url") // Ссылка на CRM застройщика
  bonus            String? // New: бонусы и акции
  promotions       String?        @map("promotions") // Специальные акции и условия
  mortgagePrograms String[]       @default([]) @map("mortgage_programs") // Доступные программы ипотеки
  images           String[]
  videoUrl         String?        @map("video_url") // New
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  developerId      String         @map("developer_id")

  // Relations
  apartments Apartment[]
  developer  User        @relation("DeveloperProjects", fields: [developerId], references: [id])

  @@index([developerId])
  @@index([city])
  @@index([district])
  @@index([buildingStatus])
  @@map("projects")
}

model Apartment {
  id          String          @id @default(cuid())
  number      String
  floor       Int
  rooms       Int
  area        Decimal         @db.Decimal(10, 2)
  price       Decimal         @db.Decimal(15, 2)
  status      ApartmentStatus @default(AVAILABLE)
  layoutImage String?         @map("layout_image")
  images      String[]        @default([]) // New: дополнительные фото квартиры
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  projectId   String          @map("project_id")

  // Relations
  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bookings             Booking[]
  mortgageCalculations MortgageCalculation[]

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@index([rooms])
  @@map("apartments")
}

model Booking {
  id          String        @id @default(cuid())
  status      BookingStatus @default(PENDING)
  expiresAt   DateTime      @map("expires_at")
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  clientId    String        @map("client_id")
  apartmentId String        @map("apartment_id")
  brokerId    String        @map("broker_id")
  apartment   Apartment     @relation(fields: [apartmentId], references: [id])
  broker      User          @relation(fields: [brokerId], references: [id])
  client      Client        @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([apartmentId])
  @@index([brokerId])
  @@index([status])
  @@map("bookings")
}

model MortgageCalculation {
  id             String     @id @default(cuid())
  propertyPrice  Decimal    @map("property_price") @db.Decimal(15, 2)
  initialPayment Decimal    @map("initial_payment") @db.Decimal(15, 2)
  loanAmount     Decimal    @map("loan_amount") @db.Decimal(15, 2)
  interestRate   Decimal    @map("interest_rate") @db.Decimal(5, 2)
  termMonths     Int        @map("term_months")
  monthlyPayment Decimal    @map("monthly_payment") @db.Decimal(15, 2)
  totalPayment   Decimal    @map("total_payment") @db.Decimal(15, 2)
  overpayment    Decimal    @db.Decimal(15, 2)
  bankName       String?    @map("bank_name")
  programName    String?    @map("program_name")
  apartmentId    String?    @map("apartment_id")
  apartmentInfo  String?    @map("apartment_info")
  createdAt      DateTime   @default(now()) @map("created_at")
  clientId       String     @map("client_id")
  client         Client     @relation(fields: [clientId], references: [id])
  apartment      Apartment? @relation(fields: [apartmentId], references: [id])

  @@index([clientId])
  @@index([apartmentId])
  @@map("mortgage_calculations")
}

model ClientDocument {
  id         String   @id @default(cuid())
  name       String
  type       String
  fileUrl    String   @map("file_url")
  fileSize   Int      @map("file_size")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  clientId   String   @map("client_id")
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_documents")
}

enum UserRole {
  ADMIN
  BROKER
  DEVELOPER
}

enum ClientStatus {
  NEW
  IN_PROGRESS
  DEAL_CLOSED
  REJECTED
}

enum ClientType {
  BUYER
  SELLER
  NEW_BUILDING
}

enum ApartmentStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  COMPLETED
}

enum BuildingStatus {
  UNDER_CONSTRUCTION
  COMPLETED
  READY_TO_MOVE
}

enum CertificationStatus {
  IN_PROGRESS
  CERTIFIED
  INACTIVE
}

enum NotificationType {
  SYSTEM
  CURATOR
  DEAL
  BONUS
  TRAINING
}

enum DealStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// New Models for v1.2

model Course {
  id           String   @id @default(cuid())
  title        String
  description  String?
  content      String   @db.Text
  duration     Int // minutes
  order        Int      @default(0)
  videoUrl     String?  @map("video_url") // Ссылка на видеоурок
  materials    String[] @default([]) // Ссылки на материалы (PDF, DOC)
  checklist    String[] @default([]) // Пункты чек-листа для курса
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  progress CourseProgress[]

  @@map("courses")
}

model CourseProgress {
  id              String    @id @default(cuid())
  progressPercent Int       @default(0) @map("progress_percent")
  isCompleted     Boolean   @default(false) @map("is_completed")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  userId          String    @map("user_id")
  courseId        String    @map("course_id")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_progress")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")
  userId    String           @map("user_id")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model MortgageProgram {
  id             String   @id @default(cuid())
  bankName       String   @map("bank_name")
  programName    String   @map("program_name")
  interestRate   Decimal  @map("interest_rate") @db.Decimal(5, 2)
  minDownPayment Decimal  @map("min_down_payment") @db.Decimal(5, 2) // percent
  maxTerm        Int      @map("max_term") // months
  propertyType   String   @map("property_type") // NEW_BUILDING, SECONDARY
  requirements   String   @db.Text
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([bankName])
  @@index([propertyType])
  @@map("mortgage_programs")
}


model Deal {
  id          String     @id @default(cuid())
  amount      Decimal    @db.Decimal(15, 2)
  commission  Decimal    @db.Decimal(15, 2) // broker commission
  casaFee     Decimal    @map("casa_fee") @db.Decimal(15, 2) // Casa fee
  status      DealStatus @default(IN_PROGRESS)
  stage       DealStage  @default(CONSULTATION) // New: Kanban stage
  order       Int        @default(0) // New: Order in column
  color       String     @default("#3B82F6") // New: Card color
  source      String     @default("MANUAL") // New: MANUAL, FORM, BOT
  objectType  String     @map("object_type") // PROPERTY, APARTMENT, BOOKING
  objectId    String?    @map("object_id") // ID объекта (property/apartment)
  clientId    String?    @map("client_id") // покупатель
  notes       String?    @db.Text
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  brokerId    String     @map("broker_id")

  // Relations
  broker User    @relation(fields: [brokerId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  @@index([brokerId])
  @@index([clientId])
  @@index([status])
  @@index([stage])
  @@index([completedAt])
  @@map("deals")
}

model LeadForm {
  id               String   @id @default(cuid())
  title            String
  fields           Json     // [{ label, type, required, options }]
  distributionType String   @default("MANUAL") @map("distribution_type") // MANUAL, ROUND_ROBIN
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  brokers User[] @relation("FormBrokers") // Brokers enabled for this form

  @@map("lead_forms")
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  isCompleted Boolean   @default(false) @map("is_completed")
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  userId      String    @map("user_id")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isCompleted])
  @@map("tasks")
}

// ... (Property model remains unchanged) ...
// Secondary Real Estate (Вторичная недвижимость)
model Property {
  id          String         @id @default(cuid())
  title       String // "3-комнатная квартира в центре"
  description String?        @db.Text
  propertyType PropertyType  @default(APARTMENT) @map("property_type") // APARTMENT, HOUSE, COMMERCIAL, LAND
  city        String
  district    String?
  address     String
  floor       Int?
  totalFloors Int?           @map("total_floors")
  rooms       Int?
  area        Decimal        @db.Decimal(10, 2)
  price       Decimal        @db.Decimal(15, 2)
  status      PropertyStatus @default(ACTIVE)
  images      String[]       @default([])
  videoUrl    String?        @map("video_url")
  yearBuilt   Int?           @map("year_built")
  condition   String? // ЕВРОРЕМОНТ, ТРЕБУЕТ РЕМОНТА, и т.д.
  features    String[] // ["БАЛКОН", "ПАРКОВКА", "МЕБЕЛЬ"]
  notes       String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  brokerId    String         @map("broker_id")
  sellerId    String?        @map("seller_id") // Client who is selling
  buyerId     String?        @map("buyer_id") // Client who bought it

  // Relations
  broker User    @relation("BrokerProperties", fields: [brokerId], references: [id])
  seller Client? @relation("SellerProperties", fields: [sellerId], references: [id])
  buyer  Client? @relation("BuyerProperties", fields: [buyerId], references: [id])

  @@index([brokerId])
  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
  @@index([city])
  @@index([propertyType])
  @@map("properties")
}

enum PropertyType {
  APARTMENT // Квартира
  HOUSE // Дом
  COMMERCIAL // Коммерция
  LAND // Участок
}

enum PropertyStatus {
  ACTIVE // Активен
  SOLD // Продан
  RESERVED // Зарезервирован
  ARCHIVED // Снят с публикации
}

// Payment History (История операций баланса)
model Payment {
  id          String      @id @default(cuid())
  amount      Decimal     @db.Decimal(15, 2)
  type        PaymentType // INCOME или EXPENSE
  description String
  createdAt   DateTime    @default(now()) @map("created_at")
  userId      String      @map("user_id")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("payments")
}

enum PaymentType {
  INCOME
  EXPENSE
}

enum DealStage {
  CONSULTATION // Консультация
  CONTRACT     // Договор
  PROMOTION    // Продвижение
  SHOWINGS     // Показы
}

